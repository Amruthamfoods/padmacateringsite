{
  "name": "padma-catering-server",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "seed": "node prisma/seed.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "lint": "eslint routes/**/*.js middleware/**/*.js utils/**/*.js --max-warnings 0",
    "lint:fix": "eslint routes/**/*.js middleware/**/*.js utils/**/*.js --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "security-audit": "npm audit --audit-level=moderate",
    "validate-env": "node -e \"require('./utils/envValidator.js')()\"",
    "validate": "npm run validate-env && npm run lint"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.16",
    "razorpay": "^2.9.4",
    "winston": "^3.11.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
"eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "prisma": "^5.22.0"
  }
}

